# ── Tracker app ─────────────────────────────────────────────────────────────
# Required: signing key for Flask sessions. Generate with: openssl rand -hex 32
TRACKER_SECRET_KEY=change-me

# Config profile: dev | prod | test
FLASK_CONFIG=dev
FLASK_APP=app:create_app

# Where the tracker writes its own database
TRACKER_DB_PATH=/config/tracker.db

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Max upload size in bytes (16 MiB)
MAX_CONTENT_LENGTH=16777216

# Container timezone
TZ=America/New_York

# ── Calibre library (read-only) ─────────────────────────────────────────────
CALIBRE_DB_PATH=/calibre-library/metadata.db
CALIBRE_LIBRARY_PATH=/calibre-library

# ── Calibre Web NextGen bridge (read-only) ──────────────────────────────────
# Path to CWN's app.db
CWA_DB_PATH=/cwa/app.db

# CWN's Flask SECRET_KEY — needed to validate signed session cookies.
# Find it in CWN's container env or config.
CWA_SECRET_KEY=

# CWN's COOKIE_PREFIX env var, if set. Cookie name = "{prefix}session".
# Check with: docker exec calibre-web printenv COOKIE_PREFIX
CWA_COOKIE_PREFIX=

# Where to send the user after /logout (CWN's logout endpoint)
CWA_BASE_URL=/

# Auth mode: cookie (Scenario A) or form (Scenario B fallback)
AUTH_MODE=cookie
